APP_NAME="Support Shelf"
COMPOSE_PROJECT_NAME=supportshelf
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://supportshelf.mkbuilds.live

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_STACK=stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=supportshelf
DB_USERNAME=supportshelf
DB_PASSWORD=change-me
DB_ROOT_PASSWORD=change-me-root

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

OPENAI_API_KEY=
OPENAI_ORGANIZATION=
OPENAI_PROJECT=
OPENAI_BASE_URL=
OPENAI_REQUEST_TIMEOUT=30
OPENAI_RESPONSES_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

VECTOR_STORE_DRIVER=weaviate
WEAVIATE_URL=http://weaviate:8080
WEAVIATE_API_KEY=
WEAVIATE_COLLECTION=support_chunks
WEAVIATE_TIMEOUT=10

CRAWLER_USER_AGENT="SupportShelfBot/1.0 (+https://supportshelf.mkbuilds.live)"
CRAWLER_TIMEOUT=20
CRAWLER_CONNECT_TIMEOUT=10
CRAWLER_DELAY_MS=750
CRAWLER_MAX_DEPTH=2

SUPPORT_ASSISTANT_NAME="SupportShelf AI"
SUPPORT_ASSISTANT_TAGLINE="Instant product support grounded in manuals and store policies."
SUPPORT_DOCUMENT_DISK=local
SUPPORT_DOCUMENT_PATH=source-documents
SUPPORT_RETRIEVAL_TOP_K=8

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_PUBLIC_HOST=supportshelf.mkbuilds.live
REVERB_PUBLIC_PORT=443
REVERB_PUBLIC_SCHEME=https
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_PUBLIC_HOST}"
VITE_REVERB_PORT="${REVERB_PUBLIC_PORT}"
VITE_REVERB_SCHEME="${REVERB_PUBLIC_SCHEME}"

APP_ROLE=web
RUN_MIGRATIONS=false
APP_SKIP_OPTIMIZE=false
QUEUE_WORKER_SLEEP=1
QUEUE_WORKER_TRIES=3
QUEUE_WORKER_TIMEOUT=120
QUEUE_WORKER_MAX_TIME=3600
